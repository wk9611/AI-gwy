{
  "version": 2,
  "installCommand": "npm install && cd server && npm install && npx prisma generate && cd ../client && npm install",
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "server/node_modules/pdfjs-dist/legacy/build/**"
    }
  }
}
